    <!-- Order Form -->
    <section class="order-section" id="order">
        <div class="section-header fade-in">
            <h2>Place Your Order</h2>
            <p>Fill in your details and we'll prepare your kenkey fresh for pickup or delivery.</p>
        </div>
        
        <div class="order-container fade-in">
            <form id="orderForm" onsubmit="submitOrder(event)">
                <div class="form-row">
                    <div class="form-group">
                        <label>Full Name</label>
                        <input type="text" id="customerName" placeholder="John Doe" required>
                    </div>
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" id="customerPhone" placeholder="024 123 4567" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" id="customerEmail" placeholder="john@example.com">
                    </div>
                    <div class="form-group">
                        <label>Delivery / Pickup</label>
                        <select id="deliveryType" required>
                            <option value="">Select option</option>
                            <option value="delivery">Home Delivery</option>
                            <option value="pickup">Pickup from Stand</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label>Delivery Address (if applicable)</label>
                    <textarea id="customerAddress" rows="3" placeholder="Enter your full address..."></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Order Type</label>
                        <select id="orderType" onchange="updateQuantity()" required>
                            <option value="">Select package</option>
                            <option value="classic">Classic Kenkey (₵15 each)</option>
                            <option value="combo">Kenkey & Fish Combo (₵35 each)</option>
                            <option value="party">Party Pack (₵120 each)</option>
                            <option value="small">Small Event Package (₵450)</option>
                            <option value="medium">Medium Event Package (₵850)</option>
                            <option value="large">Large Event Package (₵1,600)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Quantity</label>
                        <div class="quantity-selector">
                            <button type="button" class="qty-btn" onclick="changeQty(-1)">−</button>
                            <span class="qty-value" id="qtyValue">1</span>
                            <button type="button" class="qty-btn" onclick="changeQty(1)">+</button>
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label>Special Instructions</label>
                    <textarea id="specialInstructions" rows="3" placeholder="Any allergies, preferred spice level, delivery time, etc..."></textarea>
                </div>

                <div style="background: var(--white); padding: 1.5rem; border-radius: 12px; margin: 1.5rem 0; display: flex; justify-content: space-between; align-items: center;">
                    <span style="font-weight: 600;">Estimated Total:</span>
                    <span style="font-size: 1.5rem; font-weight: 700; color: var(--primary-dark);" id="estimatedTotal">₵0</span>
                </div>

                <button type="submit" class="submit-order">
                    📱 Place Order via WhatsApp
                </button>
                <p style="text-align: center; margin-top: 1rem; color: #666; font-size: 0.9rem;">
                    You'll be redirected to WhatsApp to complete your order
                </p>
            </form>
        </div>
